# =============================================================================
# LINKEDIN SCRAPER - CONFIGURATION
# =============================================================================
# Copy this file to .env and customize your settings
# All settings have sensible defaults - only change what you need

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password-here

# =============================================================================
# AI SETTINGS (Groq API)
# =============================================================================
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Generation settings
GROQ_MAX_TOKENS=4000
GROQ_TEMPERATURE=0.7
GROQ_MAX_RETRIES=3

# LaTeX
BASE_CV_PATH=templates/base_cv.tex
LATEX_COMPILER=pdflatex

# =============================================================================
# EMAIL SETTINGS
# =============================================================================
HEADLESS_MODE=false              # Run browser in background (true/false)
PAGE_LOAD_TIMEOUT=30             # Page load timeout in seconds
ELEMENT_WAIT_TIMEOUT=10          # Element wait timeout in seconds

# =============================================================================
# GOOGLE LINKEDIN SCRAPER
# =============================================================================
# Performance (lower = faster, but may trigger rate limits)
GOOGLE_PAGE_TIMEOUT=5            # Timeout for Google pages
GOOGLE_ELEMENT_TIMEOUT=3         # Timeout for elements
GOOGLE_MIN_DELAY=0.3             # Minimum delay between actions
GOOGLE_MAX_DELAY=1.0             # Maximum delay between actions
GOOGLE_PAGE_DELAY=0.5            # Delay between pages

# Limits
GOOGLE_MAX_PAGES=10              # Max pages per keyword (Google rarely shows >10)
GOOGLE_MAX_PROFILES=100          # Default max profiles
GOOGLE_PROFILES_PER_KEYWORD=20   # Profiles per keyword
GOOGLE_RESULTS_PER_PAGE=20       # Request 20 results per page

# Duplicate detection (ratio-based)
DUPLICATE_RATIO_THRESHOLD=0.7    # Skip keyword if >70% duplicates
CONSECUTIVE_BAD_PAGES=2          # Skip after N consecutive bad pages

# Logging
GOOGLE_VERBOSE=true              # Show detailed logs (true/false)

# Search
LINKEDIN_DOMAIN=linkedin.com     # Use "fr.linkedin.com" for France

# =============================================================================
# GROUP SCRAPER
# =============================================================================
GROUP_URL=                       # Default group URL to scrape
MAX_MEMBERS=0                    # 0 = unlimited
BATCH_SIZE=10                    # Members per batch save
SCROLL_TIMEOUT=10                # Scroll wait timeout
MAX_SCROLL_ATTEMPTS=3            # Max scroll attempts

# =============================================================================
# PROFILE ENRICHER
# =============================================================================
ENRICHER_PROFILE_DELAY=2.0       # Delay between profile visits
DOMAIN_SEARCH_TIMEOUT=5          # Timeout for domain search

# =============================================================================
# CONNECTION SENDER
# =============================================================================
CONN_MIN_DELAY=10                # Min delay between requests (seconds)
CONN_MAX_DELAY=30                # Max delay between requests (seconds)
MAX_CONNECTIONS_PER_DAY=50       # Daily limit
MAX_CONNECTIONS_PER_SESSION=25   # Per session limit

# =============================================================================
# MESSAGING
# =============================================================================
DEFAULT_MESSAGE=Hi! I'd like to connect.
MSG_MIN_DELAY=30                 # Min delay between messages
MSG_MAX_DELAY=60                 # Max delay between messages
MAX_MESSAGES_PER_DAY=50          # Daily limit

# =============================================================================
# API SETTINGS (Optional - for REST API)
# =============================================================================
API_KEY=your-secure-api-key
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
ENABLE_FILE_LOGGING=true         # Save logs to files
ENABLE_CONSOLE_LOGGING=true      # Print logs to console
LOG_ROTATION_SIZE=10485760       # 10MB before rotation
LOG_BACKUP_COUNT=5               # Keep 5 backup files
